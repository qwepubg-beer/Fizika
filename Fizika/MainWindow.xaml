<Window x:Class="Fizika.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Fizika"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Label Content="Вычисление массы изделия" FontFamily="Segoe UI" FontSize="20" Grid.ColumnSpan="2"></Label>
        <Grid Grid.Row="1" Height="397" VerticalAlignment="Bottom">
            <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Margin="0,5,0,0">
                <TextBlock Text="Высота:" FontFamily="Segoe UI" FontSize="20" Margin="20" VerticalAlignment="Center" HorizontalAlignment="Center" />
                <TextBlock Text="Ширина:" FontFamily="Segoe UI" FontSize="20" Margin="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <TextBlock Text="Длина:" FontFamily="Segoe UI" FontSize="20" Margin="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </StackPanel>
            <StackPanel Grid.Row="0" Grid.Column="2"  Margin="0,5,0,0">
                <TextBox Name="a" Text="" FontFamily="Segoe UI" FontSize="20" Margin="20" VerticalAlignment="Center" HorizontalAlignment="Center" Width="150" Height="25"/>
                <TextBox Name="b" Text="" FontFamily="Segoe UI" FontSize="20" Margin="20" VerticalAlignment="Center" HorizontalAlignment="Center" Width="150" Height="25"/>
                <TextBox Name="c" Text="" FontFamily="Segoe UI" FontSize="20" Margin="20" VerticalAlignment="Center" HorizontalAlignment="Center" Width="150" Height="25"/>
            </StackPanel>
            <StackPanel Grid.Row="1" Height="150"  Margin="0,5,0,0">
                <TextBlock  Text="Масса изделия:" FontFamily="Segoe UI" FontSize="20"  VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <TextBox Name="answer" Text="" FontFamily="Segoe UI" FontSize="20" Margin="20" VerticalAlignment="Center" HorizontalAlignment="Center" Width="150" Height="25"/>
            </StackPanel>
        </Grid>
        <Grid Grid.Column="1" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border BorderThickness="2" CornerRadius="5" BorderBrush="Gray" >
                <StackPanel Grid.Row="0" Grid.ColumnSpan="2"  Margin="0,5,0,0">
                <TextBlock  Text="Материал: " FontFamily="Segoe UI" FontSize="20"  VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <RadioButton x:Name="tin" GroupName="Material" Content="олово" FontFamily="Segoe UI" FontSize="20" Margin="5" IsChecked="True"/>
                <RadioButton Name="lead" GroupName="Material" Content="свинец" FontFamily="Segoe UI" FontSize="20" Margin="5" />
                <RadioButton Name="iron" GroupName="Material" Content="сталь" FontFamily="Segoe UI" FontSize="20" Margin="5"/>
                <RadioButton Name="ice" GroupName="Material" Content="лёд" FontFamily="Segoe UI" FontSize="20" Margin="5"/>
                </StackPanel>
            </Border>
            <StackPanel Grid.Row="2" Grid.Column="0" Height="150"  Margin="0,0,0,0">
                <Button Height="40" Width="150" Content="Вычислить" Margin="20" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Segoe UI" FontSize="20" Click="Button_Click" ></Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
